# ============================================================
# Campus Service - 环境变量配置（参考模板）
# ============================================================
# 复制此文件为 .env 并修改实际值。

# PostgreSQL 数据库连接
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_qa
DB_USER=postgres
DB_PASSWORD=your-db-password

# campus-service
CAMPUS_SERVICE_HOST=0.0.0.0
CAMPUS_SERVICE_PORT=8001
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
