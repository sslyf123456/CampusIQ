# ============================================================
# Campus QA Assistant - 环境变量配置（参考模板）
# ============================================================
# 复制此文件为 .env 并修改实际值。
# 各后端服务有独立的 .env（campus-service/.env, ai-service/.env），
# 外层 .env 仅作参考模板。

# PostgreSQL 数据库连接
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_qa
DB_USER=postgres
DB_PASSWORD=your-db-password

# OpenAI API（用于 Embedding 生成，ai-service 使用）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBED_BATCH_SIZE=10

# campus-service
CAMPUS_SERVICE_HOST=0.0.0.0
CAMPUS_SERVICE_PORT=8001
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ai-service
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8002
